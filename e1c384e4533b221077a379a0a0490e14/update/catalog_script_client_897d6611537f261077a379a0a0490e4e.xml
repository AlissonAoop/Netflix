        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {
   if (isLoading) {
      return;
   }

   if(newValue == '') {
	top.window.document.getElementById("poster_image").src = "";
   }

   var ga = new GlideAjax("MediaUtilsClient");
   ga.addParam("sysparm_name", "getMediaData");
   ga.addParam("sysparm_media_sys_id", newValue);

   ga.getXMLAnswer(function(response) {
	var objResponse = JSON.parse(response);
	g_form.setValue("average_rating", objResponse.average_grade);
	g_form.setValue("synopsis", objResponse.synopsis);
	top.window.document.getElementById("poster_image").src = objResponse.poster_url;
   });
}]]></script>
